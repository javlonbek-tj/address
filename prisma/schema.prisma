generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Region {
  id   String @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  name String
  code String @unique
  geometry Json
  center   Json?
  isActive Boolean @default(true)

  districts District[]
  users     AppUser[]

  @@index([name])
  @@map("regions")
}

model District {
  id       String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  regionId String
  name     String
  code     String @unique
  geometry Json
  center   Json?
  isActive Boolean @default(true)


  region   Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  mahallas Mahalla[]
  streets  Street[]
  users    AppUser[]
  properties Property[]

  @@index([name])
  @@map("districts")
}

model Mahalla {
  id   String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  code String @unique
  geometry Json
  center   Json?
  isActive Boolean @default(true)
  uzKadName String
  geoCode   String
  oneId     String
  isOptimized Boolean @default(false)
  oldName       String?
  regulation    String?
  regulationUrl String?

  mergedInto     Mahalla[] @relation("MahallaMerge")
  mergedMahallas Mahalla[] @relation("MahallaMerge")
  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  streets    Street[]
  properties Property[]

  @@index([name])
  @@map("mahallas")
}

model Street {
  id   String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  code String @unique
  geometry Json
  center   Json?
  isActive Boolean @default(true)
  type      String
  oldNameId String?
  oldName   String?
  uzKadCode String?


  districtId String
  district   District @relation(fields: [districtId], references: [id])
  mahalla    Mahalla[]

  properties Property[]

  @@index([name])
  @@map("streets")
}

model Property {
  id           String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cadNumber    String?   @unique
  newCadNumber String?   @unique
  newHouseNumber String?
  oldHouseNumber String?
  oldStreetName  String?
  oldMahallaName String?
  type         String   @default("residential")
  isNew        Boolean  @default(false)
  geometry Json
  center   Json?
  isActive Boolean @default(true)

  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  mahallaId String?
  mahalla   Mahalla?  @relation(fields: [mahallaId], references: [code], onDelete: Cascade)
  streetId String?
  street   Street?   @relation(fields: [streetId], references: [code], onDelete: Cascade)

  @@map("properties")
}

model user {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  username      String?   @unique
  displayUsername String?

  sessions      session[]
  accounts      account[]

  appUser       AppUser?

  @@map("auth_identities")
}

model session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("auth_accounts")
}


model AppUser {
  id          String  @id @default(cuid())
  fullName    String?
  phoneNumber String?

  role     UserRole   @default(district_user)
  status   UserStatus @default(active)
  isActive Boolean    @default(true)

  authId String? @unique
  auth   user?   @relation(fields: [authId], references: [id], onDelete: Cascade)

  regionId String?
  region   Region?             @relation(fields: [regionId], references: [id], onDelete: Cascade)
  position RegionUserPosition?

  districtId String?
  district   District?         @relation(fields: [districtId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([regionId])
  @@index([districtId])
  @@map("users")
}

enum UserRole {
  superadmin
  admin
  region_user
  district_user
}

enum RegionUserPosition {
  boss
  assistant
}

enum UserStatus {
  active
  inactive
}
